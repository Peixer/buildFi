  "types": [
    {
      "name": "Milestone",
      "docs": [
        "Single milestone: fixed name, funding percentage, status, estimated completion (Unix secs, `0` = unset)."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "name",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "percentage",
            "type": "u8"
          },
          {
            "name": "status",
            "type": "u8"
          },
          {
            "name": "estimatedCompletion",
            "type": "i64"
          }
        ]
      }
    }
  ],
