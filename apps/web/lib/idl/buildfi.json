{
  "version": "0.1.0",
  "name": "buildfi",
  "instructions": [
    {
      "name": "initialize",
      "accounts": [],
      "args": []
    },
    {
      "name": "createProject",
      "docs": [
        "Create a new project: project account (keypair), vault PDA, participation mint.",
        "Project authority PDA signs for vault and mint."
      ],
      "accounts": [
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "projectAuthority",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "PDA used to sign vault and participation mint operations. Validated in instruction."
          ]
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Vault is the ATA of project_authority for USDC. Created in instruction via CPI."
          ]
        },
        {
          "name": "participationMint",
          "isMut": true,
          "isSigner": true,
          "docs": [
            "Participation token mint. Keypair must sign (required for create_account CPI).",
            "Created in instruction via create_account + initialize_mint2."
          ]
        },
        {
          "name": "usdcMint",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "associatedTokenProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "rent",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "builder",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "type": "string",
                "value": "builder"
              },
              {
                "kind": "account",
                "type": "publicKey",
                "path": "owner"
              }
            ]
          }
        }
      ],
      "args": [
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "description",
          "type": "string"
        },
        {
          "name": "fundingTarget",
          "type": "u64"
        },
        {
          "name": "milestones",
          "type": {
            "vec": {
              "defined": "Milestone"
            }
          }
        },
        {
          "name": "builderName",
          "type": "string"
        },
        {
          "name": "builderDescription",
          "type": "string"
        },
        {
          "name": "stage",
          "type": "u8"
        },
        {
          "name": "projectCode",
          "type": "string"
        },
        {
          "name": "imageUrl",
          "type": "string"
        },
        {
          "name": "locationName",
          "type": "string"
        },
        {
          "name": "geoLat",
          "type": "i64"
        },
        {
          "name": "geoLng",
          "type": "i64"
        },
        {
          "name": "vision",
          "type": "string"
        },
        {
          "name": "investmentThesis",
          "type": "string"
        },
        {
          "name": "programRulesUrl",
          "type": "string"
        },
        {
          "name": "projectDocsUrl",
          "type": "string"
        },
        {
          "name": "milestonesDocsUrl",
          "type": "string"
        },
        {
          "name": "durationDays",
          "type": "u64"
        },
        {
          "name": "riskLevel",
          "type": "u8"
        },
        {
          "name": "targetReturnBps",
          "type": "u16"
        }
      ]
    },
    {
      "name": "deposit",
      "docs": [
        "Deposit USDC into project vault and mint 1:1 participation tokens to buyer."
      ],
      "accounts": [
        {
          "name": "buyer",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "buyerAccount",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "type": "string",
                "value": "buyer"
              },
              {
                "kind": "account",
                "type": "publicKey",
                "account": "Project",
                "path": "project"
              },
              {
                "kind": "account",
                "type": "publicKey",
                "path": "buyer"
              }
            ]
          }
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": false,
          "relations": [
            "vault",
            "participation_mint"
          ]
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "buyerUsdcAta",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Must be buyer's USDC ATA (validated in instruction to avoid stack overflow)."
          ]
        },
        {
          "name": "buyerParticipationAta",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Must be buyer's participation ATA (validated in instruction to avoid stack overflow)."
          ]
        },
        {
          "name": "participationMint",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "usdcMint",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "projectAuthority",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "type": "string",
                "value": "project_authority"
              },
              {
                "kind": "account",
                "type": "publicKey",
                "account": "Project",
                "path": "project"
              }
            ]
          }
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        }
      ]
    },
    {
      "name": "releaseCapital",
      "docs": [
        "Release capital to project owner for the next milestone.",
        "Amount = current vault balance * milestone_pct / 100 (percentage of current balance, not of funding target).",
        "On the final milestone, any remaining vault balance (rounding dust) is swept to the owner."
      ],
      "accounts": [
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": false,
          "relations": [
            "owner",
            "vault"
          ]
        },
        {
          "name": "projectAuthority",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "type": "string",
                "value": "project_authority"
              },
              {
                "kind": "account",
                "type": "publicKey",
                "account": "Project",
                "path": "project"
              }
            ]
          }
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "ownerUsdcAta",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Must be owner's USDC ATA (validated in instruction to avoid stack overflow)."
          ]
        },
        {
          "name": "usdcMint",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "refund",
      "docs": [
        "Refund buyer's full deposit (only when no milestone has been released). Burns participation tokens."
      ],
      "accounts": [
        {
          "name": "buyer",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "buyerAccount",
          "isMut": true,
          "isSigner": false,
          "relations": [
            "project"
          ]
        },
        {
          "name": "project",
          "isMut": false,
          "isSigner": false,
          "relations": [
            "vault",
            "participation_mint"
          ]
        },
        {
          "name": "projectAuthority",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "type": "string",
                "value": "project_authority"
              },
              {
                "kind": "account",
                "type": "publicKey",
                "account": "Project",
                "path": "project"
              }
            ]
          }
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "buyerUsdcAta",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Must be buyer's USDC ATA (validated in instruction to avoid stack overflow)."
          ]
        },
        {
          "name": "buyerParticipationAta",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Must be buyer's participation ATA (validated in instruction to avoid stack overflow)."
          ]
        },
        {
          "name": "participationMint",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "usdcMint",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "deleteProject",
      "docs": [
        "Close project (only when vault balance is zero). Refund or release all funds first.",
        "Note: Buyer PDAs and the participation mint are not closed (SPL mints cannot be closed; Buyer accounts remain as historical data)."
      ],
      "accounts": [
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "project",
          "isMut": true,
          "isSigner": false,
          "relations": [
            "owner",
            "vault",
            "participation_mint"
          ]
        },
        {
          "name": "projectAuthority",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "type": "string",
                "value": "project_authority"
              },
              {
                "kind": "account",
                "type": "publicKey",
                "account": "Project",
                "path": "project"
              }
            ]
          }
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "participationMint",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "Builder",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "owner",
            "type": "publicKey"
          },
          {
            "name": "name",
            "docs": [
